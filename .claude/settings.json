{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "--package=@upstash/context7-mcp@2.2.5",
        "--",
        "context7-mcp"
      ]
    },
    "engram": {
      "command": "/opt/homebrew/bin/engram",
      "args": [
        "mcp",
        "--tools=agent"
      ]
    },
    "vercel": {
      "command": "npx",
      "args": ["-y", "@vercel/mcp-adapter"],
      "env": {
        "VERCEL_TOKEN": "${VERCEL_TOKEN}"
      }
    }
  }
}
