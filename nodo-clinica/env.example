# Copiar a `.env.local` en desarrollo o pegar en Vercel → Environment Variables
#
# ── Deploy Vercel (proyecto nodo-clinica, Root Directory = nodo-clinica) ──
# Activar "Include source files outside Root Directory" (monorepo pnpm).
# NEXT_PUBLIC_APP_URL=https://www.nodocore.com.ar
# CLINIC_SESSION_SECRET=<random 32+ chars>
# BLOB_READ_WRITE_TOKEN=<Vercel Blob>
# JAAS_PRIVATE_KEY=<base64 o PEM en una línea con \n> (no usar PATH en Vercel)
#
# ── Deploy Vercel (proyecto nodo-landing / nodocore.com.ar) ──
# NODO_CLINICA_URL=https://nodo-clinica.vercel.app
# (no hace falta NODO_CLINICA_REMOTE_PREFIX: default /clinica tras redeploy de clinica)

# Modo demo (recomendado hoy)
CLINIC_MODE=local
NEXT_PUBLIC_CLINIC_MODE=local
# URL pública (detrás de nodocore.com.ar usar el dominio del landing + /clinica)
NEXT_PUBLIC_APP_URL=https://nodocore.com.ar
# En Vercel/prod el basePath /clinica se aplica solo (next.config). Forzar en dev+landing:
# NEXT_PUBLIC_BASE_PATH=/clinica

# Vercel Blob — obligatorio en producción
BLOB_READ_WRITE_TOKEN=

# Gemini — SOAP, informes, validación de comprobantes (gratis en aistudio.google.com/apikey)
# Sin clave: la app arma borradores locales sin costo.
GEMINI_API_KEY=
NEXT_PUBLIC_CLINIC_STRICT_PAYMENT=true
CLINIC_STRICT_PAYMENT_VALIDATION=true

# Vademécum nacional (Argly — datos públicos AR). Desactivar: VADEMECUM_DISABLE=true
# VADEMECUM_API_URL=https://api.argly.com.ar/v1/medicamentos

NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# JaaS (8x8) — videoconsultas sin límite de 5 min (ver JAAS-SETUP.md)
# NEXT_PUBLIC_JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxx
# JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxx
# JAAS_API_KEY_ID=vpaas-magic-cookie-xxxxxxxx/tu-kid-tras-subir-public-key
# JAAS_PRIVATE_KEY_PATH=./jaasauth.key
# JAAS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# NEXT_PUBLIC_JITSI_DOMAIN=8x8.vc

# Zoho SMTP — confirmaciones, recordatorios y emails transaccionales
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465
# ZOHO_SMTP_USER=contacto@nodocore.com.ar
# ZOHO_SMTP_PASSWORD=

# Email de destino del botón "Enviar email de prueba" (recordatorios)
# REMINDER_TEST_EMAIL=tu@correo.com

# Mercado Pago — PASARELA (solo quien despliega la app; el médico NO ve esto)
# Crear app en https://www.mercadopago.com.ar/developers/panel/app
# Copiar Client ID y Client Secret (NO el Access Token del vendedor).
# Redirect URI en el panel MP (misma URL en dev y prod según corresponda):
#   Local:  http://localhost:3002/api/clinic/mercadopago/oauth/callback
#   Prod:   https://TU-DOMINIO/api/clinic/mercadopago/oauth/callback
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# MERCADOPAGO_OAUTH_REDIRECT_URI=http://localhost:3002/api/clinic/mercadopago/oauth/callback
# MERCADOPAGO_OAUTH_TEST_TOKEN=true
# Si OAuth falla con «Tenemos un problema», probá sin PKCE: MERCADOPAGO_OAUTH_PKCE=false
# (o activá PKCE en Detalles de la app en developers.mercadopago.com)
# MERCADOPAGO_WEBHOOK_SECRET=
# MERCADOPAGO_DEFAULT_EXTERNAL_POS_ID=
#
# El médico vincula SU cuenta en Configuración → Cobros:
#   - OAuth (botón) si CLIENT_ID/SECRET están arriba, o
#   - Pegar su Access Token (TEST-… / APP_USR-…) y Guardar cambios

# Supabase (futuro — no configurar si usás modo local)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
