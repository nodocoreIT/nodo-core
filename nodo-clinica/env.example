# Copiar a `.env.local` en desarrollo o pegar en Vercel → Environment Variables

# Modo demo (recomendado hoy)
CLINIC_MODE=local
NEXT_PUBLIC_CLINIC_MODE=local
NEXT_PUBLIC_APP_URL=https://tu-app.vercel.app

# Vercel Blob — obligatorio en producción
BLOB_READ_WRITE_TOKEN=

# Gemini — SOAP, informes, validación de comprobantes
GEMINI_API_KEY=
NEXT_PUBLIC_CLINIC_STRICT_PAYMENT=true
CLINIC_STRICT_PAYMENT_VALIDATION=true

# Vademécum nacional (Argly — datos públicos AR). Desactivar: VADEMECUM_DISABLE=true
# VADEMECUM_API_URL=https://api.argly.com.ar/v1/medicamentos

NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# JaaS (8x8) — videoconsultas sin límite de 5 min (ver JAAS-SETUP.md)
# NEXT_PUBLIC_JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxx
# JAAS_APP_ID=vpaas-magic-cookie-xxxxxxxx
# JAAS_API_KEY_ID=vpaas-magic-cookie-xxxxxxxx/tu-kid-tras-subir-public-key
# JAAS_PRIVATE_KEY_PATH=./jaasauth.key
# JAAS_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# NEXT_PUBLIC_JITSI_DOMAIN=8x8.vc

# Opcional
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Clínica Virtual <noreply@tudominio.com>

# Mercado Pago OAuth (cada médico conecta su cuenta)
MERCADOPAGO_CLIENT_ID=
MERCADOPAGO_CLIENT_SECRET=
# MERCADOPAGO_OAUTH_REDIRECT_URI=https://tu-app.vercel.app/api/clinic/mercadopago/oauth/callback
# MERCADOPAGO_OAUTH_TEST_TOKEN=true
# MERCADOPAGO_DEFAULT_EXTERNAL_POS_ID=
# Secreto de firma de webhooks (panel MP → Webhooks → revelar clave)
# MERCADOPAGO_WEBHOOK_SECRET=
# CLINIC_ADMIN_SECRET=

# Fallback dev (sin OAuth por médico)
# CLINIC_MERCADOPAGO_ACCESS_TOKEN=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# Auth migration feature flag
# Set to true to activate Supabase Auth; false falls back to legacy cookie auth
USE_SUPABASE_AUTH=false
