{
  "name": "nodocore",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.30.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "dev:core": "turbo dev --filter=nodo-core",
    "dev:inmo": "turbo dev --filter=nodo-inmo",
    "dev:clinica": "turbo dev --filter=nodo-clinica",
    "dev:all": "turbo dev --filter=nodo-core --filter=nodo-inmo",
    "dev:autos": "turbo dev --filter=nodo-autos",
    "dev:finanzas": "pnpm --filter nodo-finanzas dev"
  },
  "devDependencies": {
    "turbo": "latest"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7"
    }
  }
}
